// ── SMTP feedback credentials ─────────────────────────────────────────────────
// Copy this file to smtp_creds.rs and fill in real values.
// smtp_creds.rs is gitignored — it will never be committed.
//
// To get a QQ SMTP auth code: mail.qq.com → 设置 → 账户 → POP3/SMTP服务 → 生成授权码
//
// SMTP 授权码建议经 XOR 编码存储，防止本地 strings 直接提取。
// 泄露仍可登录 mail.qq.com 重置授权码（旧码即刻失效）。

const SMTP_USER: &str = "your_sender@qq.com";
const SMTP_AUTH_ENCODED: &[u8] = &[0x00]; // XOR(real_auth_code, KEY)
const SMTP_TO: &str = "your_recipient@qq.com";
const SMTP_TIMEOUT_SECS: u64 = 10;

fn smtp_auth_code() -> String {
    const KEY: u8 = 0xB7;
    SMTP_AUTH_ENCODED.iter().map(|b| (b ^ KEY) as char).collect()
}
