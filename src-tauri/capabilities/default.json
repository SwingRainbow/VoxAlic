{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main + notify popup windows",
  "windows": ["main", "notify"],
  "permissions": [
    "core:default",
    "opener:default",
    "core:event:default",
    "core:event:allow-emit",
    "core:event:allow-listen"
  ]
}
